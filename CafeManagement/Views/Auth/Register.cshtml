@model CafeManagement.Models.ViewModels.RegisterViewModel
@{
    ViewData["Title"] = "Register";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Register — ☕ CafeManagement</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <style>
        body {
            background: linear-gradient(135deg, #2C1810, #6F4E37);
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            font-family: 'Segoe UI', sans-serif;
        }
        .auth-card {
            background: white;
            border-radius: 20px;
            padding: 40px;
            width: 100%;
            max-width: 420px;
            box-shadow: 0 20px 60px rgba(0,0,0,0.3);
        }
        .auth-logo { font-size: 2.5rem; text-align: center; margin-bottom: 8px; }
        .auth-title { text-align: center; color: #2C1810; font-weight: 700; margin-bottom: 4px; }
        .auth-subtitle { text-align: center; color: #888; font-size: 0.9rem; margin-bottom: 28px; }
        .btn-cafe {
            background: #6F4E37; color: white; border: none;
            border-radius: 25px; padding: 10px; width: 100%;
            font-size: 1rem; font-weight: 600; transition: 0.3s;
        }
        .btn-cafe:hover { background: #2C1810; color: white; }
        .form-control:focus { border-color: #6F4E37; box-shadow: 0 0 0 0.2rem rgba(111,78,55,0.2); }
    </style>
</head>
<body>
    <div class="auth-card">
        <div class="auth-logo">☕</div>
        <h3 class="auth-title">নতুন Account</h3>
        <p class="auth-subtitle">Register করে শুরু করুন</p>

        <form asp-action="Register" method="post">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2" style="display:@(ViewData.ModelState.IsValid ? "none" : "block")"></div>

            <div class="mb-3">
                <label asp-for="Name" class="form-label fw-semibold">নাম</label>
                <input asp-for="Name" class="form-control" placeholder="আপনার নাম" />
                <span asp-validation-for="Name" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Email" class="form-label fw-semibold">Email</label>
                <input asp-for="Email" class="form-control" placeholder="email@example.com" />
                <span asp-validation-for="Email" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Password" class="form-label fw-semibold">Password</label>
                <input asp-for="Password" class="form-control" placeholder="কমপক্ষে 6 character" />
                <span asp-validation-for="Password" class="text-danger small"></span>
            </div>

            <div class="mb-4">
                <label asp-for="ConfirmPassword" class="form-label fw-semibold">Password আবার</label>
                <input asp-for="ConfirmPassword" class="form-control" placeholder="••••••" />
                <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
            </div>

            <button type="submit" class="btn-cafe">Register করুন</button>
        </form>

        <hr class="my-3" />
        <p class="text-center mb-0" style="font-size:0.9rem">
            আগেই account আছে?
            <a asp-action="Login" style="color:#6F4E37; font-weight:600">Login করুন</a>
        </p>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
