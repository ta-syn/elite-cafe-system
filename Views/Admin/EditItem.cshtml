@model CafeManagement.Models.ViewModels.AddMenuItemViewModel
@{
    ViewData["Title"] = "Item Edit";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="row justify-content-center">
    <div class="col-md-7">
        <div class="card-admin p-4">
            <h5 class="mb-4" style="color:#2C1810">
                <i class="fas fa-edit me-2" style="color:#6F4E37"></i>Item Edit করুন
            </h5>

            <form asp-action="EditItem" asp-route-id="@ViewBag.ItemId" method="post">
                @Html.AntiForgeryToken()
                <div class="mb-3">
                    <label class="form-label fw-semibold">Item Type</label>
                    <select asp-for="ItemType" class="form-select" disabled>
                        <option value="Beverage">☕ Beverage</option>
                        <option value="Food">🍽️ Food</option>
                    </select>
                    <input type="hidden" asp-for="ItemType" />
                </div>

                <div class="row">
                    <div class="col-md-7 mb-3">
                        <label asp-for="Name" class="form-label fw-semibold">নাম</label>
                        <input asp-for="Name" class="form-control" />
                        <span asp-validation-for="Name" class="text-danger small"></span>
                    </div>
                    <div class="col-md-5 mb-3">
                        <label asp-for="Price" class="form-label fw-semibold">দাম (৳)</label>
                        <input asp-for="Price" class="form-control" />
                        <span asp-validation-for="Price" class="text-danger small"></span>
                    </div>
                </div>

                <div class="mb-3">
                    <label asp-for="Description" class="form-label fw-semibold">Description</label>
                    <input asp-for="Description" class="form-control" />
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="ImageEmoji" class="form-label fw-semibold">Emoji</label>
                        <select asp-for="ImageEmoji" class="form-select">
                            <option value="☕">☕ Coffee</option>
                            <option value="🥛">🥛 Milk</option>
                            <option value="🧊">🧊 Cold</option>
                            <option value="🍵">🍵 Tea</option>
                            <option value="🥤">🥤 Drink</option>
                            <option value="🍽️">🍽️ Food</option>
                            <option value="🥪">🥪 Sandwich</option>
                            <option value="🍝">🍝 Pasta</option>
                            <option value="🥐">🥐 Pastry</option>
                            <option value="🍰">🍰 Cake</option>
                        </select>
                    </div>
                    <div class="col-md-6 mb-3 d-flex align-items-end">
                        <div class="form-check">
                            <input asp-for="IsAvailable" class="form-check-input" type="checkbox" />
                            <label asp-for="IsAvailable" class="form-check-label fw-semibold">Available</label>
                        </div>
                    </div>
                </div>

                @if (Model.ItemType == "Beverage")
                {
                    <hr />
                    <p class="fw-semibold text-muted small mb-2">BEVERAGE OPTIONS</p>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="Size" class="form-label fw-semibold">Size</label>
                            <select asp-for="Size" class="form-select">
                                <option value="Small">Small</option>
                                <option value="Medium">Medium</option>
                                <option value="Large">Large</option>
                            </select>
                        </div>
                        <div class="col-md-6 d-flex align-items-end mb-3">
                            <div class="form-check">
                                <input asp-for="IsHot" class="form-check-input" type="checkbox" />
                                <label asp-for="IsHot" class="form-check-label fw-semibold">Hot Drink</label>
                            </div>
                        </div>
                    </div>
                }
                else
                {
                    <hr />
                    <p class="fw-semibold text-muted small mb-2">FOOD OPTIONS</p>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="PrepTimeMinutes" class="form-label fw-semibold">Prep Time (min)</label>
                            <input asp-for="PrepTimeMinutes" class="form-control" />
                        </div>
                        <div class="col-md-6 d-flex align-items-end mb-3">
                            <div class="form-check">
                                <input asp-for="IsVegetarian" class="form-check-input" type="checkbox" />
                                <label asp-for="IsVegetarian" class="form-check-label fw-semibold">Vegetarian</label>
                            </div>
                        </div>
                    </div>
                }

                <div class="d-flex gap-2 mt-3">
                    <button type="submit" class="btn btn-cafe">
                        <i class="fas fa-save me-1"></i> Update
                    </button>
                    <a asp-action="MenuList" class="btn btn-outline-secondary rounded-pill">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>
