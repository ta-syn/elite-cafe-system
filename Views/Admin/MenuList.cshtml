@using CafeManagement.Models
@model List<MenuItem>
@{
    ViewData["Title"] = "Menu Items";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <form method="get" class="d-flex">
        <input type="text" name="search" class="form-control me-2"
               placeholder="Search items... (hidden items সহ)" value="@ViewBag.Search" style="width:250px" />
        <button type="submit" class="btn btn-cafe">🔍</button>
    </form>
    <a asp-action="AddItem" class="btn btn-cafe">
        <i class="fas fa-plus me-1"></i> নতুন Item
    </a>
</div>

<div class="card-admin p-3">
    @if (!Model.Any())
    {
        <p class="text-muted text-center py-4">কোনো item পাওয়া যায়নি।</p>
    }
    else
    {
        <table class="table">
            <thead>
                <tr>
                    <th>Item</th>
                    <th>ধরন</th>
                    <th>দাম</th>
                    <th>Description</th>
                    <th>Available</th>
                    <th>Action</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>
                            <span style="font-size:1.3rem">@item.ImageEmoji</span>
                            <strong class="ms-2">@item.Name</strong>
                        </td>
                        <td>
                            <span class="badge bg-secondary">
                                @(item is Beverage ? "Beverage" : "Food")
                            </span>
                        </td>
                        <td style="color:#6F4E37; font-weight:600">৳@item.Price</td>
                        <td class="text-muted small">@item.GetDescription()</td>
                        <td>
                            <form asp-action="ToggleAvailability" method="post" class="d-inline">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@item.Id" />
                                <button type="submit"
                                        class="btn btn-sm @(item.IsAvailable ? "btn-success" : "btn-outline-secondary") rounded-pill">
                                    @(item.IsAvailable ? "✅ Available" : "❌ Hidden")
                                </button>
                            </form>
                        </td>
                        <td>
                            <a asp-action="EditItem" asp-route-id="@item.Id"
                               class="btn btn-sm btn-outline-primary rounded-pill me-1">
                                ✏️ Edit
                            </a>
                            <form asp-action="DeleteItem" method="post" class="d-inline"
                                  onsubmit="return confirm('@item.Name delete করবে?')">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@item.Id" />
                                <button type="submit" class="btn btn-sm btn-outline-danger rounded-pill">
                                    🗑️ Delete
                                </button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>
