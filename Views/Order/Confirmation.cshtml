@model CafeManagement.Models.Order
@{
    ViewData["Title"] = "Order Confirmed";
}

<div class="row justify-content-center">
    <div class="col-md-6 text-center">
        <div class="card card-cafe p-5">
            <div style="font-size:4rem">✅</div>
            <h3 class="mt-3" style="color:#2C1810">Order Confirmed!</h3>
            <p class="text-muted">আপনার order পাওয়া গেছে। ধন্যবাদ!</p>

            <div class="rounded p-3 my-3" style="background:#FFF3E0">
                <h5>Order #@Model.Id</h5>
                <p class="mb-1">মোট: <strong style="color:#6F4E37">৳@Model.TotalAmount</strong></p>
                <p class="mb-0 text-muted small">Status: @Model.Status</p>
            </div>

            <div class="d-grid gap-2 mt-3">
                <a asp-controller="Order" asp-action="Detail"
                   asp-route-id="@Model.Id" class="btn btn-cafe">
                    Order Details দেখুন
                </a>
                <a asp-controller="Menu" asp-action="Index"
                   class="btn btn-outline-secondary rounded-pill">
                    Menu তে ফিরুন
                </a>
            </div>
        </div>
    </div>
</div>
