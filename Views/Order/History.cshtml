@using CafeManagement.Models
@using CafeManagement.Models.Enums
@model List<Order>
@{
    ViewData["Title"] = "Order History";
}

<h2 class="mb-4" style="color:#2C1810">📋 আমার Orders</h2>

@if (!Model.Any())
{
    <div class="text-center py-5">
        <p style="font-size:3rem">📭</p>
        <h5 class="text-muted">এখনো কোনো order নেই</h5>
        <a asp-controller="Menu" asp-action="Index" class="btn btn-cafe mt-3">
            Menu দেখুন
        </a>
    </div>
}
else
{
    <div class="card card-cafe p-3">
        <table class="table table-hover mb-0">
            <thead>
                <tr style="background:#FFF3E0">
                    <th>#</th>
                    <th>তারিখ</th>
                    <th>Items</th>
                    <th>মোট</th>
                    <th>Status</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var order in Model)
                {
                    <tr>
                        <td class="fw-bold">#@order.Id</td>
                        <td class="text-muted small">@order.CreatedAt.ToString("dd MMM, hh:mm tt")</td>
                        <td>@order.Items.Count items</td>
                        <td class="fw-bold" style="color:#6F4E37">৳@order.TotalAmount</td>
                        <td>
                            <span class="badge-@order.Status.ToString().ToLower()">
                                @order.Status
                            </span>
                        </td>
                        <td>
                            <a asp-action="Detail" asp-route-id="@order.Id"
                               class="btn btn-sm btn-outline-secondary rounded-pill">
                                দেখুন
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
