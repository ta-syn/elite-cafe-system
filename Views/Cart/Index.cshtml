@using CafeManagement.Models
@model List<CartItem>
@{
    ViewData["Title"] = "Cart";
}

<h2 class="mb-4" style="color:#2C1810">🛒 আমার Cart</h2>

@if (!Model.Any())
{
    <div class="text-center py-5">
        <p style="font-size:4rem">🛒</p>
        <h5 class="text-muted">Cart empty!</h5>
        <a asp-controller="Menu" asp-action="Index" class="btn btn-cafe mt-3">
            Menu দেখুন
        </a>
    </div>
}
else
{
    <div class="row">
        <div class="col-md-8">
            <div class="card card-cafe p-3 mb-3">
                <table class="table table-borderless mb-0">
                    <thead>
                        <tr style="border-bottom:2px solid #FFF3E0">
                            <th>Item</th>
                            <th>দাম</th>
                            <th>পরিমাণ</th>
                            <th>মোট</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>
                                    <span style="font-size:1.4rem">@item.ImageEmoji</span>
                                    <span class="ms-2 fw-semibold">@item.ItemName</span>
                                </td>
                                <td>৳@item.UnitPrice</td>
                                <td>
                                    <form asp-action="UpdateQty" method="post" class="d-flex align-items-center">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="itemId" value="@item.MenuItemId" />
                                        <button type="submit" name="quantity"
                                                value="@(item.Quantity - 1)"
                                                class="btn btn-sm btn-outline-secondary">−</button>
                                        <span class="mx-2 fw-bold">@item.Quantity</span>
                                        <button type="submit" name="quantity"
                                                value="@(item.Quantity + 1)"
                                                class="btn btn-sm btn-outline-secondary">+</button>
                                    </form>
                                </td>
                                <td class="fw-bold" style="color:#6F4E37">৳@item.Subtotal</td>
                                <td>
                                    <form asp-action="Remove" method="post">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="itemId" value="@item.MenuItemId" />
                                        <button type="submit" class="btn btn-sm btn-outline-danger">✕</button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card card-cafe p-4">
                <h5 style="color:#2C1810">Order Summary</h5>
                <hr />
                <div class="d-flex justify-content-between mb-2">
                    <span>Items (@Model.Count)</span>
                    <span>৳@Model.Sum(c => c.Subtotal)</span>
                </div>
                <div class="d-flex justify-content-between fw-bold mb-4" style="font-size:1.1rem">
                    <span>মোট</span>
                    <span style="color:#6F4E37">৳@ViewBag.Total</span>
                </div>
                <form asp-action="Checkout" method="post">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-cafe w-100">
                        ✅ Order দিন
                    </button>
                </form>
                <a asp-controller="Menu" asp-action="Index"
                   class="btn btn-outline-secondary w-100 mt-2 rounded-pill">
                    ← Menu তে ফিরুন
                </a>
            </div>
        </div>
    </div>
}
