<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Admin — @ViewData["Title"]</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet" />
    <style>
        body { background: #f4f6f9; font-family: 'Segoe UI', sans-serif; margin: 0; }
        .sidebar {
            width: 240px; min-height: 100vh;
            background: #2C1810; position: fixed;
            top: 0; left: 0; padding-top: 0;
        }
        .sidebar-brand {
            padding: 20px; font-size: 1.2rem;
            font-weight: 700; color: #D4A574;
            border-bottom: 1px solid rgba(255,255,255,0.1);
        }
        .sidebar .nav-link {
            color: rgba(255,255,255,0.75);
            padding: 12px 20px; border-radius: 8px;
            margin: 2px 10px; transition: 0.2s;
        }
        .sidebar .nav-link:hover,
        .sidebar .nav-link.active {
            background: rgba(255,255,255,0.1);
            color: #D4A574;
        }
        .sidebar .nav-link i { width: 22px; }
        .main-content { margin-left: 240px; padding: 24px; }
        .top-bar {
            background: white; padding: 14px 24px;
            box-shadow: 0 2px 8px rgba(0,0,0,0.06);
            margin: -24px -24px 24px -24px;
            display: flex; justify-content: space-between;
            align-items: center;
        }
        .top-bar h5 { margin: 0; color: #2C1810; font-weight: 700; }
        .top-bar .user-info { color: #6F4E37; font-size: 0.9rem; }
        .card-admin {
            border: none; border-radius: 14px;
            box-shadow: 0 2px 12px rgba(0,0,0,0.07);
            background: white;
        }
        .stat-card { border-radius: 14px; color: white; padding: 22px; }
        .stat-card-1 { background: linear-gradient(135deg, #6F4E37, #C8860A); }
        .stat-card-2 { background: linear-gradient(135deg, #2C1810, #6F4E37); }
        .stat-card-3 { background: linear-gradient(135deg, #C8860A, #D4A574); }
        .stat-card-4 { background: linear-gradient(135deg, #e74c3c, #c0392b); }
        .stat-card .stat-value { font-size: 2rem; font-weight: 700; }
        .stat-card .stat-label { font-size: 0.85rem; opacity: 0.85; }
        .btn-cafe { background: #6F4E37; color: white; border: none; border-radius: 20px; padding: 7px 18px; transition: 0.3s; }
        .btn-cafe:hover { background: #2C1810; color: white; }
        .badge-pending   { background: #FFF3CD; color: #856404; padding: 4px 10px; border-radius: 15px; font-size: 0.8rem; font-weight: 600; }
        .badge-preparing { background: #CCE5FF; color: #004085; padding: 4px 10px; border-radius: 15px; font-size: 0.8rem; font-weight: 600; }
        .badge-ready     { background: #D4EDDA; color: #155724; padding: 4px 10px; border-radius: 15px; font-size: 0.8rem; font-weight: 600; }
        .badge-served    { background: #E2E3E5; color: #383D41; padding: 4px 10px; border-radius: 15px; font-size: 0.8rem; font-weight: 600; }
        .badge-cancelled { background: #F8D7DA; color: #721c24; padding: 4px 10px; border-radius: 15px; font-size: 0.8rem; font-weight: 600; }
        .table th { background: #FFF8F0; color: #2C1810; font-weight: 600; border: none; }
        .table td { vertical-align: middle; border-color: #f0e8e0; }
    </style>
</head>
<body>

<div class="sidebar">
    <div class="sidebar-brand">☕ Cafe Admin</div>
    <nav class="mt-3">
        <a asp-controller="Admin" asp-action="Dashboard"
           class="nav-link @(ViewContext.RouteData.Values["action"]?.ToString() == "Dashboard" ? "active" : "")">
            <i class="fas fa-chart-bar"></i> Dashboard
        </a>
        <a asp-controller="Admin" asp-action="MenuList"
           class="nav-link @(ViewContext.RouteData.Values["action"]?.ToString()?.Contains("Item") == true || ViewContext.RouteData.Values["action"]?.ToString() == "MenuList" ? "active" : "")">
            <i class="fas fa-utensils"></i> Menu Items
        </a>
        <a asp-controller="Admin" asp-action="AllOrders"
           class="nav-link @(ViewContext.RouteData.Values["action"]?.ToString()?.Contains("Order") == true ? "active" : "")">
            <i class="fas fa-clipboard-list"></i> সব Orders
        </a>
        <hr style="border-color:rgba(255,255,255,0.1); margin: 10px 20px;" />
        <a asp-controller="Menu" asp-action="Index" class="nav-link">
            <i class="fas fa-store"></i> Shop দেখুন
        </a>
        <a asp-controller="Auth" asp-action="Logout" class="nav-link">
            <i class="fas fa-sign-out-alt"></i> Logout
        </a>
    </nav>
</div>

<div class="main-content">
    <div class="top-bar">
        <h5>@ViewData["Title"]</h5>
        <div class="user-info">
            <i class="fas fa-user-circle me-1"></i>
            @Context.Session.GetString("UserName") — Admin
        </div>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show">
            <i class="fas fa-check-circle me-2"></i>@TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show">
            <i class="fas fa-exclamation-circle me-2"></i>@TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @RenderBody()
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
@RenderSection("Scripts", required: false)
</body>
</html>
